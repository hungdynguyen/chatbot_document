*.parquet
*.feather
*.hdf5
*.h5

# ===== DOCKER =====
# Docker files (keep Dockerfile but ignore others)
docker-compose.override.yml
.dockerignore

# ===== SYSTEM FILES =====
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ===== IDE/EDITOR =====
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# PyCharm
.idea/

# Sublime Text
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ===== TEMPORARY FILES =====
# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo

# ===== TESTING =====
# Test files
test_uploads/
test_data/
test_results/
coverage_reports/

# ===== API KEYS & SECRETS =====
# Environment variables
.env*
secrets/
api_keys/
credentials/

# ===== DOCUMENTATION =====
# Documentation build
docs/_build/
docs/build/

# ===== MONITORING & LOGS =====
# Log files
logs/
*.log
*.log.*
access.log
error.log
debug.log

# Monitoring data
monitoring/
metrics/

# ===== CUSTOM PROJECT SPECIFIC =====
# Frontend build artifacts
frontend/build/
frontend/dist/
frontend/.next/

# Backend artifacts
backend/dist/
backend/build/

# Data files (don't commit sensitive data)
data/private/
data/sensitive/
data/customer/

# Backup files
backup/
backups/
*.backup

# Configuration overrides
config.local.*
settings.local.*

# ===== DEPENDENCIES =====
# Package manager files
package-lock.json
yarn.lock
Pipfile.lock
poetry.lock

# ===== DEPLOYMENT =====
# Deployment scripts with secrets
deploy_prod.sh
deploy_staging.sh
kubernetes/secrets/

# ===== PERFORMANCE =====
# Profile data
*.prof
profile_*

# Benchmark results
benchmark_*
perf_*

# ===== KEEP THESE (EXPLICITLY TRACKED) =====
# Don't ignore these important files
!.gitkeep
!README.md
!requirements.txt
!package.json
!Dockerfile
!docker-compose.yml
!.github/
